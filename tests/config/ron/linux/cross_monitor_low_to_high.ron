(
    version: 2,
    entries: [
        (
            key: Primary,
            state: (
                // X11 cross-monitor: saved on Monitor 0 (eDP, scale 2, pos 1512,2880), launched from Monitor 1 (HDMI, scale 1)
                // Tests position/size restoration when crossing from low DPI to high DPI
                logical_position: Some((1712, 3080)),
                logical_width: 1000,
                logical_height: 700,
                monitor_scale: 1.0,
                monitor_index: 0,
                mode: Windowed,
                app_name: "restore_window",
            )
        ),
    ],
)
