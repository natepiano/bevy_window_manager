(
    version: 2,
    entries: [
        (
            key: Primary,
            state: (
                // X11 cross-monitor: saved on Monitor 0 (eDP), launched from Monitor 1 (HDMI)
                // Tests position/size restoration when crossing from low DPI to high DPI
                logical_position: Some((${MONITOR_0_LOGICAL_POS_X+200}, ${MONITOR_0_LOGICAL_POS_Y+200})),
                logical_width: 1000,
                logical_height: 700,
                monitor_scale: 1.0,
                monitor_index: 0,
                mode: Windowed,
                app_name: "restore_window",
            )
        ),
    ],
)
